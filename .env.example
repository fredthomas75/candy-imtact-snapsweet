# ─── Stripe ───────────────────────────────────────────────────────────────────
# Récupère tes clés à https://dashboard.stripe.com/test/apikeys
# En dev, utilise les clés de TEST : sk_test_... et pk_test_...
# En prod : sk_live_... et pk_live_... (différents environnements Vercel).

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx

# Webhook secret — pour vérifier la signature des événements Stripe.
# En local : lance `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#           → le CLI affiche un whsec_... à coller ici.
# En prod : dashboard.stripe.com → Developers → Webhooks → ajouter un endpoint
#           sur https://<ton-domaine>/api/webhooks/stripe puis copier le secret.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ─── Site ─────────────────────────────────────────────────────────────────────
# URL publique du site, sans slash final.
# En local : http://localhost:3000
# En prod : https://snapsweet.ca
# En preview Vercel : laisser vide, la chaîne de fallback détecte VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
