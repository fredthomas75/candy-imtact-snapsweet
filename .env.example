# Stripe — paiement
# Récupère tes clés à https://dashboard.stripe.com/apikeys
# En dev, utilise les clés de test (sk_test_... / pk_test_...).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx

# URL publique du site, sans slash final
# En local : http://localhost:3000
# En prod : https://snapsweet.ca
# En preview Vercel : laisser vide, la chaîne de fallback détecte VERCEL_URL automatiquement.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
